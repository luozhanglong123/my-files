# MMPBSA.py input file for Chitinase-Chitin_Hexamer system
#
# GOAL: Get accurate binding enthalpy (MM/PBSA) 
#

#=================== GENERAL SECTION ===================
&general
   startframe=1,
   interval=1,
   verbose=1,
   keep_files=2,
/

#================ PB CALCULATION SECTION =================
# This section is for the most ACCURATE binding enthalpy calculation.
&pb
   inp=2,
   indi=4.0,
   exdi=80.0,
   istrng=0.10,
   radiopt=0,
/

